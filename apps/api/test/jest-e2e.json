{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^@generated/(.*)$": "<rootDir>/../generated/$1",
    "^@thallesp/nestjs-better-auth$": "<rootDir>/mocks/nestjs-better-auth.ts"
  }
}
