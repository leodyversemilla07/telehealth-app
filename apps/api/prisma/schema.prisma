generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // Generate CJS-compatible TypeScript so the compiled output works
  // with NestJS's CJS emit (required by experimentalDecorators).
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  PROVIDER
  ADMIN
}

enum Language {
  FILIPINO
  ENGLISH
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum VisitType {
  VIDEO
  PHONE
  IN_PERSON
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  Boolean   @default(false)
  mobile         String?   @unique
  mobileVerified Boolean   @default(false)
  preferredLang  Language  @default(FILIPINO)
  name           String?
  image          String?
  role           Role      @default(PATIENT)
  banned         Boolean   @default(false)
  banReason      String?
  banExpires     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 2FA Fields
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String?

  sessions         Session[]
  accounts         Account[]
  securityAlerts   SecurityAlert[]
  patientProfile   PatientProfile?
  providerProfile  ProviderProfile?
  consentLogs      ConsentLog[]
  patientAppointments Appointment[] @relation("PatientAppointments")
}

model Session {
  id         String   @id @default(cuid())
  expiresAt  DateTime
  token      String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  ipAddress  String?
  userAgent  String?
  userId     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @default("")
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model PatientProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dob              DateTime?
  sex              String?
  phone            String?
  address          String?
  philhealthNumber String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("patient_profiles")
}

model ProviderProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty             String
  prcLicenseNumber      String   @unique
  prcLicenseExpiry      DateTime
  philhealthAccreditation String?
  pdeaS2License         String?
  pdeaS2Expiry          DateTime?
  bio                   String?
  clinicAddress         String?
  pricePerVisit         Decimal  @db.Decimal(10, 2)
  isApproved            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  availabilities Availability[]
  timeOff        TimeOff[]
  appointments   Appointment[] @relation("ProviderAppointments")

  @@map("provider_profiles")
}

model Availability {
  id           String         @id @default(cuid())
  providerId   String
  provider     ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  dayOfWeek    Int             // 0=Sun, 1=Mon ... 6=Sat
  startTime    String          // HH:mm format (24h), e.g. "09:00"
  endTime      String          // HH:mm format (24h), e.g. "17:00"
  slotDuration Int             // minutes (15, 30, or 60)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([providerId, dayOfWeek, startTime, endTime])
  @@map("availabilities")
}

model TimeOff {
  id         String   @id @default(cuid())
  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  date       DateTime        @db.Date
  startTime  String          // HH:mm format (24h)
  endTime    String          // HH:mm format (24h)
  reason     String?
  createdAt  DateTime @default(now())

  @@map("time_off")
}

model Appointment {
  id         String            @id @default(cuid())
  patientId  String
  patient    User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  providerId String
  provider   ProviderProfile   @relation("ProviderAppointments", fields: [providerId], references: [id], onDelete: Cascade)
  startTime  DateTime
  endTime    DateTime
  status     AppointmentStatus @default(BOOKED)
  reason     String?
  symptoms   String?
  language   Language?
  type       VisitType         @default(VIDEO)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([patientId])
  @@index([providerId])
  @@index([startTime])
  @@map("appointments")
}

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType String   // privacy_policy, data_sharing, recording, marketing
  granted     Boolean
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("consent_logs")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  actorId      String
  actorEmail   String
  targetId     String?
  targetEmail  String?
  reason       String?
  timestamp    DateTime @default(now())

  @@map("audit_logs")
}

model SecurityAlert {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  ipAddress String?
  userAgent String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_alerts")
}