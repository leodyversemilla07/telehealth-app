{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "node -e \"const fs=require('node:fs');const cp=require('node:child_process');if(fs.existsSync('prisma/schema.prisma')){try{cp.execSync('pnpm exec prisma generate',{stdio:'inherit'})}catch{console.warn('Skipping prisma generate during postinstall')}}\"",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "biome lint",
    "format": "biome check --write",
    "format:check": "biome check",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@thallesp/nestjs-better-auth": "^2.7.0",
    "@workspace/shared": "workspace:*",
    "better-auth": "^1.6.23",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "isomorphic-dompurify": "^3.18.0",
    "livekit-server-sdk": "^2.17.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@types/web-push": "^3.6.4",
    "@workspace/typescript-config": "workspace:*",
    "jest": "^30.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^isomorphic-dompurify$": "<rootDir>/../test/mocks/isomorphic-dompurify.ts",
      "^@generated/prisma/client\\.js$": "<rootDir>/../test/mocks/prisma-client.ts",
      "^@thallesp/nestjs-better-auth$": "<rootDir>/../test/mocks/nestjs-better-auth.ts",
      "^@/prisma/prisma\\.service$": "<rootDir>/../test/mocks/prisma.service.ts",
      "^@/notifications/notifications\\.service$": "<rootDir>/../test/mocks/notifications.service.ts",
      "^@workspace/shared$": "<rootDir>/../test/mocks/workspace-shared.ts",
      "generated/prisma/client\\.js$": "<rootDir>/../test/mocks/prisma-client.ts",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
