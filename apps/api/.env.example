# =============================================================================
# Telehealth App API — Environment Variables
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Better Auth ─────────────────────────────────────────────────────────────
# Generate a secure secret:  openssl rand -base64 32
# Must be at least 32 characters long.
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your_secure_secret_here_at_least_32_chars

# ── OAuth Providers (optional) ──────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Object Storage (optional — defaults to local filesystem) ────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=telehealth-app-uploads
# S3_PUBLIC_URL=https://cdn.yourdomain.com

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# Generate an App Password at https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# ── LiveKit Cloud (REQUIRED in production) ─────────────────────────────────
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Session ─────────────────────────────────────────────────────────────────
# How long a user session lasts (in seconds). Default: 7 days (604800).
# Minimum: 5 minutes (300). Maximum: 30 days (2592000).
# SESSION_EXPIRY_SECONDS=604800

# ── AI Recommendations (optional) ──────────────────────────────────────────
# NIM_API_KEY=

# ── Data Retention (optional, defaults below) ──────────────────────────────
# RETENTION_NOTIFICATIONS_DAYS=90
# RETENTION_SECURITY_ALERTS_DAYS=730
# RETENTION_AUDIT_LOGS_DAYS=2555