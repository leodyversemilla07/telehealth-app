# =============================================================================
# Telehealth App API — Environment Variables
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Better Auth (CRITICAL FOR EMAIL VERIFICATION) ──────────────────────────
# Generate a secure secret:  openssl rand -base64 32
# Must be at least 32 characters long.
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your_secure_secret_here_at_least_32_chars

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Cookie Domain (production only) ────────────────────────────────────────
# Set to your domain for cross-subdomain cookies (e.g., .tele-health.app)
# Leave empty for localhost development
COOKIE_DOMAIN=

# ── Email Configuration ─────────────────────────────────────────────────────
# Provider: "ses" (AWS SES), "gmail" (development), or leave empty for Ethereal
EMAIL_PROVIDER=ses
EMAIL_FROM="Telehealth Platform <noreply@tele-health.app>"

# ── AWS SES (Production) ───────────────────────────────────────────────────
# For SES, use the SMTP interface from AWS Console
# AWS Console → SES → Verified Identities → SMTP Settings
SMTP_ENDPOINT=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-ses-smtp-access-key
SMTP_PASS=your-ses-smtp-secret-key

# ── Gmail SMTP (Development Only) ──────────────────────────────────────────
# Generate an App Password at https://myaccount.google.com/apppasswords
# EMAIL_PROVIDER=gmail
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password

# ── AWS S3 (File Storage) ──────────────────────────────────────────────────
# REQUIRED for production - local storage loses files on redeploy!
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=telehealth-ephil-uploads
S3_PUBLIC_URL=https://your-cloudfront-distribution.cloudfront.net

# ── LiveKit Cloud (Video Calls) ────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Session ─────────────────────────────────────────────────────────────────
# How long a user session lasts (in seconds). Default: 7 days (604800).
SESSION_EXPIRY_SECONDS=604800

# ── AI Recommendations (optional) ──────────────────────────────────────────
# NIM_API_KEY=

# ── Data Retention (optional, defaults below) ──────────────────────────────
# RETENTION_NOTIFICATIONS_DAYS=90
# RETENTION_SECURITY_ALERTS_DAYS=730
# RETENTION_AUDIT_LOGS_DAYS=2555

# ── Web Push (VAPID) ───────────────────────────────────────────────────────
# Generate once: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(JSON.stringify(k))"
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:admin@tele-health.app
