# =============================================================================
# Telehealth App API — Environment Variables (Local Development)
# =============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Better Auth ─────────────────────────────────────────────────────────────
# Generate a secure secret:  openssl rand -base64 32
# Must be at least 32 characters long.
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=your_secure_secret_here_at_least_32_chars

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Cookie Domain (production only) ─────────────────────────────────────────
# Leave empty for localhost development.
# Set to your domain for cross-subdomain cookies (e.g., .tele-health.app).
COOKIE_DOMAIN=

# ── Email Configuration ─────────────────────────────────────────────────────
# Provider: "smtp" (any SMTP server), "gmail", or leave empty for Ethereal.
# Local default uses Ethereal (preview-only), which is enough for dev.
EMAIL_PROVIDER=
EMAIL_FROM="Telehealth Platform <noreply@localhost>"

# ── SMTP (Local Dev: e.g. Mailhog / Gmail) ──────────────────────────────────
# Mailhog (Docker):  SMTP_ENDPOINT=localhost, SMTP_PORT=1025, no auth
# Gmail (App Password): EMAIL_PROVIDER=gmail
SMTP_ENDPOINT=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── File Storage ────────────────────────────────────────────────────────────
# Local storage is used by default — files are written under apps/api/uploads.
# Leave S3 config blank unless switching to S3 for local dev.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=

# ── LiveKit (Video Calls) ───────────────────────────────────────────────────
# Use LiveKit Cloud or a local LiveKit server.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Session ─────────────────────────────────────────────────────────────────
# How long a user session lasts (in seconds). Default: 7 days (604800).
SESSION_EXPIRY_SECONDS=604800

# ── AI Recommendations (optional) ───────────────────────────────────────────
# NIM_API_KEY=

# ── Data Retention (optional, defaults below) ───────────────────────────────
# RETENTION_NOTIFICATIONS_DAYS=90
# RETENTION_SECURITY_ALERTS_DAYS=730
# RETENTION_AUDIT_LOGS_DAYS=2555

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate once: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(JSON.stringify(k))"
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:admin@localhost
