# =============================================================================
# Telehealth App Web — Environment Variables
# =============================================================================

# ── API Server ──────────────────────────────────────────────────────────────
# Server-side API URL (used by Next.js server components, API routes, rewrites)
API_URL=http://localhost:3001

# ── Client-Side ─────────────────────────────────────────────────────────────
# Public API URL exposed to the browser (must include /api prefix)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Must match the VAPID_PUBLIC_KEY in the API's .env
NEXT_PUBLIC_VAPID_KEY=your-public-key
