# AWS Deployment Environment Variables
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Database (use AWS RDS)
DATABASE_URL=postgresql://user:pass@endpoint:5432/dbname

# Auth
BETTER_AUTH_URL=https://api.yourdomain.com
BETTER_AUTH_SECRET=your-secret-managed-in-ssm

# CORS
CORS_ORIGIN=https://app.yourdomain.com,https://www.yourdomain.com

# API URLs
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ECR
ECR_REPOSITORY_API=next-monorepo-api
ECR_REPOSITORY_WEB=next-monorepo-web