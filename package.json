{
  "name": "telehealth-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "pnpm --filter api start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:api": "pnpm --filter api test",
    "test:web": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "format": "biome check --write",
    "format:check": "biome check",
    "seed": "pnpm --filter api exec tsx prisma/seed.ts",
    "db:seed": "pnpm seed",
    "migrate": "pnpm --filter api exec prisma migrate deploy",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:reset": "pnpm --filter api exec prisma migrate reset --force && pnpm seed",
    "db:studio": "pnpm --filter api exec prisma studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@nestjs/cli": "^11.0.23",
    "@workspace/typescript-config": "workspace:*",
    "concurrently": "^9.2.1",
    "prisma": "^7.8.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {}
}
