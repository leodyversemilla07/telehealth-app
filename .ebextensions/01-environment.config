option_settings:
  # ── Node.js Platform ──────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:container:nodejs
    option_name: NodeCommand
    value: "npm install --omit=dev && npx prisma migrate deploy"
  - namespace: aws:elasticbeanstalk:container:nodejs
    option_name: ProxyServer
    value: nginx

  # ── Health Monitoring ────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application
    option_name: Application Healthcheck URL
    value: /
  - namespace: aws:elasticbeanstalk:healthreporting:system
    option_name: SystemType
    value: enhanced

  # ── Deployment Strategy ──────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:command
    option_name: DeploymentPolicy
    value: AllAtOnce

  # ── Application Port ─────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: PORT
    value: "3001"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: NODE_ENV
    value: "production"

  # ── Better Auth (CRITICAL!) ──────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: BETTER_AUTH_URL
    value: "https://api.tele-health.app"
  # BETTER_AUTH_SECRET - set via: eb setenv BETTER_AUTH_SECRET=xxx

  # ── CORS ─────────────────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: CORS_ORIGIN
    value: "https://tele-health.app"

  # ── Cookie Domain ────────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: COOKIE_DOMAIN
    value: ".tele-health.app"

  # ── Email (AWS SES) ─────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: EMAIL_PROVIDER
    value: "ses"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: EMAIL_FROM
    value: "Telehealth Platform <noreply@tele-health.app>"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: SMTP_ENDPOINT
    value: "email-smtp.us-east-1.amazonaws.com"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: SMTP_PORT
    value: "587"

  # ── S3 Storage ───────────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: AWS_REGION
    value: "us-east-1"
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: S3_BUCKET
    value: "telehealth-ephil-uploads"

  # ── Session ──────────────────────────────────────────────────────────────
  - namespace: aws:elasticbeanstalk:application:environment
    option_name: SESSION_EXPIRY_SECONDS
    value: "604800"

  # ── VPC ──────────────────────────────────────────────────────────────────
  - namespace: aws:ec2:vpc
    option_name: ELBScheme
    value: public
