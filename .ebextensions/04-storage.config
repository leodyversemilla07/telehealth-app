option_settings:
  aws:autoscaling:launchconfiguration:
    RootVolumeSize: 20
    RootVolumeType: gp3

  # RDS encryption at rest — requires a KMS key
  # Must be set at database creation time; existing DBs need snapshot migration
  aws:rds:dbinstance:
    DBEngine: postgres
    DBInstanceClass: db.t3.micro
    DBAllocatedStorage: 20
    DBStorageEncrypted: true
    DBStorageKMSKeyId: alias/aws/rds  # Use AWS-managed key, or replace with your KMS key ARN
