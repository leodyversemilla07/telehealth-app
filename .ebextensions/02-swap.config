commands:
  01_create_swap:
    command: |
      if [ ! -f /swapfile ]; then
        fallocate -l 2G /swapfile
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile none swap sw 0 0' >> /etc/fstab
        echo 'Swap file created and enabled'
      else
        echo 'Swap file already exists'
      fi
