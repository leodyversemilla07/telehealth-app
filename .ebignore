# =============================================================================
# Elastic Beanstalk Ignore File (for Docker deployment)
# =============================================================================

# ── Git ─────────────────────────────────────────────────────────────────────
.git
.gitignore

# ── Node ────────────────────────────────────────────────────────────────────
node_modules
apps/*/node_modules
packages/*/node_modules

# ── IDE ─────────────────────────────────────────────────────────────────────
.idea
.vscode
*.swp
*.swo

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Environment files (secrets via EB env vars) ─────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Documentation ───────────────────────────────────────────────────────────
docs
*.md
!README.md

# ── Build artifacts ─────────────────────────────────────────────────────────
.turbo
.next
out
dist
build

# ── Testing ─────────────────────────────────────────────────────────────────
coverage
*.spec.ts
*.test.ts

# ── Scripts ─────────────────────────────────────────────────────────────────
scripts

# ── Local Docker Compose (not for EB) ──────────────────────────────────────
docker-compose*.yml
docker-compose*.yaml

# ── Local development files ─────────────────────────────────────────────────
uploads/
