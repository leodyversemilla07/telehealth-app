# =============================================================================
# Elastic Beanstalk Ignore File (Node.js Platform)
# =============================================================================

# ── Git ─────────────────────────────────────────────────────────────────────
.git
.gitignore

# ── Node ────────────────────────────────────────────────────────────────────
node_modules
apps/*/node_modules
packages/*/node_modules

# ── IDE ─────────────────────────────────────────────────────────────────────
.idea
.vscode
*.swp
*.swo

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Environment files ───────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Documentation ───────────────────────────────────────────────────────────
docs
*.md
!README.md

# ── Build artifacts ─────────────────────────────────────────────────────────
.turbo
.next
out
dist
build

# ── Testing ─────────────────────────────────────────────────────────────────
coverage
*.spec.ts
*.test.ts

# ── Scripts ─────────────────────────────────────────────────────────────────
scripts

# ── Docker files ────────────────────────────────────────────────────────────
Dockerfile
docker-compose*.yml
.proxy

# ── Local development ──────────────────────────────────────────────────────
uploads/
